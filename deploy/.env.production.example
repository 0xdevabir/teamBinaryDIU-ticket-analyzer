# =============================================================================
# Production environment — copy to project root as .env on the VM
#   cp deploy/.env.production.example .env
#   nano .env   # set DOMAIN, passwords, CORS
# =============================================================================

# ── Domain (required for SSL) ────────────────────────────────────────────────
DOMAIN=tickets.example.com
LETSENCRYPT_EMAIL=admin@example.com

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=ticket_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=ticket_analyzer
POSTGRES_PORT=5432

# ── Backend ──────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ticket_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/ticket_analyzer
DEBUG=false
CORS_ORIGINS=https://tickets.example.com

# ── AI ───────────────────────────────────────────────────────────────────────
AI_INFERENCE_MODE=auto
HF_API_TOKEN=
HF_ZERO_SHOT_MODEL=typeform/distilbert-base-uncased-mnli
HF_SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
AI_REQUEST_TIMEOUT=60

# ── Frontend (internal — host Nginx terminates SSL) ──────────────────────────
FRONTEND_PORT=8080
VITE_API_BASE_URL=/api/v1
