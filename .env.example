# =============================================================================
# Ticket Analyzer — Environment variables
# Copy to .env:  cp .env.example .env
# =============================================================================

# PostgreSQL
POSTGRES_USER=ticket_user
POSTGRES_PASSWORD=ticket_secret
POSTGRES_DB=ticket_analyzer
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ticket_user:ticket_secret@postgres:5432/ticket_analyzer
DEBUG=false
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,http://127.0.0.1:5173

# AI inference mode: local | api | auto
# local  — CPU inference inside container (no token needed)
# api    — Hugging Face Inference API (requires HF_API_TOKEN)
# auto   — try local, then api, then keyword fallback (recommended)
AI_INFERENCE_MODE=auto
HF_API_TOKEN=
HF_ZERO_SHOT_MODEL=typeform/distilbert-base-uncased-mnli
HF_SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
AI_REQUEST_TIMEOUT=30
SEED_ENABLED=true
PRELOAD_MODELS_ON_STARTUP=false

# Frontend (production nginx on port 80)
# Windows: if port 80 is blocked, set FRONTEND_PORT=8080
FRONTEND_PORT=80
VITE_API_BASE_URL=/api/v1

# Cross-platform Docker tuning
DB_WAIT_ATTEMPTS=30
DB_WAIT_DELAY=2
